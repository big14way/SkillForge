# ---------------------------------------------------------------------------
# 0G Chain RPC configuration
# ---------------------------------------------------------------------------
GALILEO_RPC_URL=https://evmrpc-testnet.0g.ai
GALILEO_CHAIN_ID=16602
MAINNET_RPC_URL=https://evmrpc.0g.ai
MAINNET_CHAIN_ID=16661

# Block explorer
EXPLORER_URL=https://chainscan-galileo.0g.ai

# ---------------------------------------------------------------------------
# Deployer configuration
# ---------------------------------------------------------------------------
# Private key of the EOA used to broadcast deployments.
# Use a fresh key — NEVER reuse a mainnet key here.
PRIVATE_KEY=0x

# Address that receives the 5% protocol fee on every rental.
PROTOCOL_TREASURY=0x

# ---------------------------------------------------------------------------
# v2 role addresses (defaults to the deployer if unset — fine for the demo)
# ---------------------------------------------------------------------------
# Authorized re-encryption oracle for ERC-7857 transfer/clone proofs.
ORACLE_ADDRESS=0x

# Whitelisted quality-scorer oracle for SkillEscrow.verifyWork attestations.
SCORER_ADDRESS=0x

# ---------------------------------------------------------------------------
# v2 live contract addresses (Galileo, redeployed 2026-04-16)
# ---------------------------------------------------------------------------
SKILL_INFT_ADDRESS=0x8486E62b5975A4241818b564834A5f51ae2540B6
SKILL_REGISTRY_ADDRESS=0xe3D37E5c036CC0bb4E0A170D49cc9212ABc8f985
SKILL_ESCROW_ADDRESS=0x6e6e076893c6b9eAc90463cd0E3021404F9B27B1

# ---------------------------------------------------------------------------
# 0G Storage + KV
# ---------------------------------------------------------------------------
OG_STORAGE_INDEXER_RPC=https://indexer-storage-testnet-turbo.0g.ai
OG_KV_NODE_RPC=http://3.101.147.150:6789
OG_KV_STREAM_ID=
OG_FLOW_CONTRACT_ADDRESS=

# ---------------------------------------------------------------------------
# 0G Compute
# ---------------------------------------------------------------------------
OG_COMPUTE_LEDGER_OG=0.1
TEEML_PROVIDER_ADDRESS=

# Canonical Galileo Compute contract addresses (April 2026 — provided by
# 0G core team in the APAC Dev Telegram). The installed
# @0glabs/0g-serving-broker@0.4.4 hardcodes stale defaults; we always pass
# these through explicitly. Override for mainnet when that ships.
OG_COMPUTE_INFERENCE_CONTRACT=0xa79F4c8311FF93C06b8CfB403690cc987c93F91E
OG_COMPUTE_LEDGER_CONTRACT=0xE70830508dAc0A97e6c087c75f402f9Be669E406
OG_COMPUTE_FINETUNING_CONTRACT=0xaC66eBd174435c04F1449BBa08157a707B6fa7b1

# ---------------------------------------------------------------------------
# Block-explorer verification (leave blank if 0G explorer is not supported)
# ---------------------------------------------------------------------------
ETHERSCAN_API_KEY=
