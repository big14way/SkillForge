{
  "marketplace": {
    "name": "OpenAI Chat (oai-chat)",
    "description": "GPT-4o / o1 inference with TEE attestation. Drop-in for any agent that calls the OpenAI Chat Completions API — your key never leaves the TEE.",
    "category": "content",
    "pricePerUseOG": "0.001"
  },
  "wrapper": {
    "kind": "openai-chat",
    "endpoint": "https://api.openai.com/v1/chat/completions",
    "apiKeyEnvVar": "OAI_API_KEY",
    "defaultModel": "gpt-4o-mini",
    "allowedModels": ["gpt-4o-mini", "gpt-4o", "o1-mini", "o1-preview"],
    "rateLimit": { "rpm": 60, "tpm": 200000 },
    "tags": ["llm", "openai", "chat"]
  },
  "demo": {
    "input": {
      "model": "gpt-4o-mini",
      "messages": [{ "role": "user", "content": "Summarize Bitcoin in one sentence." }]
    },
    "expectedOutputShape": "{ content: string, usage: { prompt_tokens, completion_tokens } }"
  }
}
