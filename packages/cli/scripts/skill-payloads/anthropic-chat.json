{
  "marketplace": {
    "name": "Anthropic Messages (anthropic-chat)",
    "description": "Claude 3.5 Sonnet / Opus inference with TEE attestation. Drop-in for any agent that calls Anthropic's Messages API — your key stays sealed.",
    "category": "content",
    "pricePerUseOG": "0.001"
  },
  "wrapper": {
    "kind": "anthropic-chat",
    "endpoint": "https://api.anthropic.com/v1/messages",
    "apiKeyEnvVar": "ANTHROPIC_API_KEY",
    "defaultModel": "claude-3-5-sonnet-latest",
    "allowedModels": [
      "claude-3-5-haiku-latest",
      "claude-3-5-sonnet-latest",
      "claude-3-opus-latest"
    ],
    "rateLimit": { "rpm": 50, "tpm": 200000 },
    "tags": ["llm", "anthropic", "claude", "chat"]
  },
  "demo": {
    "input": {
      "model": "claude-3-5-sonnet-latest",
      "max_tokens": 256,
      "messages": [{ "role": "user", "content": "Why do DAOs fail? Three bullet points." }]
    },
    "expectedOutputShape": "{ content: [{ text }], usage: { input_tokens, output_tokens } }"
  }
}
